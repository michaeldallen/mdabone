{
  "image": "mcr.microsoft.com/devcontainers/universal:6",
  "features": {
    "./features/devcontainer-hybrid-auth": {}
  },
  "postCreateCommand": "bash ./.devcontainer/run-postCreateCommand.sh",
  "customizations": {
    "codespaces": {
      "repositories": {
        "michaeldallen/3d": {
          "permissions": {
            "contents": "write",
            "pull_requests": "write",
            "issues": "write"
          }
        }
      }
    },
    "vscode": {
      "extensions": [],
      "settings": {
        "git.autofetch": true,
        "git.detectSubmodules": true,
        "git.submoduleLimit": 10,
        "terminal.integrated.env.linux": {
          "PATH": "${env:PATH}:${userHome}/.local/bin"
        }
      }
    }
  }
}